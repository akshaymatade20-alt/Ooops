class Employee {

 String name;

 double baseSalary;

 // Constructor

 Employee(String name, double baseSalary) {

 this.name = name;

 this.baseSalary = baseSalary;

 }

 // Method to compute salary (to be overridden)

 double calculateSalary() {

 return baseSalary;

 }

 void display() {

 System.out.println("Name: " + name);

 System.out.println("Salary: " + calculateSalary());

 }

}

// Derived class Manager

class Manager extends Employee {

 double bonus;

 Manager(String name, double baseSalary, double bonus) {

 super(name, baseSalary);

 this.bonus = bonus;

 }

 // Overriding salary calculation

 @Override

 double calculateSalary() {

 return baseSalary + bonus;

 }

}

// Derived class Developer

class Developer extends Employee {

 double overtimePay;

 Developer(String name, double baseSalary, double overtimePay) {

 super(name, baseSalary);

 this.overtimePay = overtimePay;

 }

 // Overriding salary calculation

 @Override

 double calculateSalary() {

 return baseSalary + overtimePay;

 }

}
// Main class

public class EmployeeTest {

 public static void main(String[] args) {

 Manager m = new Manager("Malhar", 50000, 10000);

 Developer d = new Developer("Vedant", 40000, 5000);

 System.out.println("Manager Details:");

 m.display();

 System.out.println("\nDeveloper Details:");

 d.display();

 }

}

